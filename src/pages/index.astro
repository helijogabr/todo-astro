---
import TodoHandler from "@components/TodoHandler.astro";
import Layout from "@layouts/Layout.astro";

if (!(await Astro.session?.get("userId"))) {
  return Astro.redirect("/login");
}
---

<Layout>
  <!-- fully center -->
  <main class="flex flex-col items-center justify-center min-h-screen">
    <TodoHandler server:defer />
  </main>
</Layout>
